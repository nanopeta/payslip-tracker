@keyframes flipInUp { 
  0% { transform: perspective(400px) rotateX(-90deg); opacity: 0; }
  40% { transform: perspective(400px) rotateX(5deg); }
  70% { transform: perspective(400px) rotateX(-5deg); }
  100% { transform: perspective(400px) rotateX(0deg); opacity: 1; }
}

@keyframes flipInRight { 
  0% { transform: perspective(100px) rotateY(-90deg); opacity: 0; }
  40% { transform: perspective(100px) rotateY(5deg); }
  70% { transform: perspective(100px) rotateY(-5deg); }
  100% { transform: perspective(100px) rotateY(0deg); opacity: 1; }
}

.flipIn { backface-visibility: visible !important; }

.flipIn.top, .flipIn.bottom { animation-name: flipInUp; }

.flipIn.left, .flipIn.right { animation-name: flipInUp; }

